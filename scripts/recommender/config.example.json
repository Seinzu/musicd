    "catalog": "external-catalog.json",
    "embeddings": "embeddings.json",
    "recommendations": "recommendations.json"
  },
  "catalog": {
    "enabled": true,
    "reuseExisting": true,
    "limit": 250,
    "topGenres": 8,
