{
  "collection": "seed.json",
  "database": {
    "enabled": true,
    "path": "recommender.sqlite"
  },
  "artifacts": {
    "profile": "profile.json",
    "catalog": "external-catalog.json",
    "recommendations": "recommendations.json"
  },
  "catalog": {
    "enabled": true,
    "reuseExisting": true,
    "candidateCatalog": "mb-candidate-catalog.jsonl",
    "limit": 50000,
    "topGenres": 12,
    "topArtists": 20,
    "perQuery": 25,
    "recentPerQuery": 25,
    "lastfmDelayMs": 250
  },
  "embeddings": {
    "enabled": true,
    "reuseExisting": true,
    "baseUrl": "http://127.0.0.1:1234/v1",
    "model": "text-embedding-qwen3-embedding-8b",
    "batchSize": 32,
    "dimensions": 1536
  },
  "recommendations": {
    "enabled": true,
    "seeds": [
      "AIR - Moon Safari",
      "A Tribe Called Quest - Midnight Marauders"
    ],
    "ownedCount": 5,
    "discoveryCount": 5,
    "recentDiscoveryCount": 2,
    "poolSize": 120,
    "format": "import"
  }
}
