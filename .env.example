# Copy this file to .env and adjust paths for your machine.

# Host port exposed at http://localhost:${MUSICD_HOST_PORT}
MUSICD_HOST_PORT=8787

# Host paths used by docker compose. The config path stores musicd.db and artwork.
MUSICD_CONFIG_HOST_PATH=./.musicd/config
MUSICD_LIBRARY_HOST_PATH=./.musicd/music

# Optional sqlite-web tools service port. Start with:
# sh scripts/compose-local.sh --profile tools up --build
SQLITE_WEB_HOST_PORT=8080

# Optional stub UPnP renderer for local queue/transport testing. The container
# advertises this URL to other Compose services; the host can inspect it at
# http://localhost:${STUB_RENDERER_HOST_PORT}/stub/state.
STUB_RENDERER_HOST_PORT=9091
STUB_RENDERER_PUBLIC_HOST=stub-renderer
STUB_RENDERER_PUBLIC_PORT=9091
STUB_RENDERER_PUBLIC_BASE_URL=http://stub-renderer:9091
STUB_RENDERER_NAME=musicd Stub Renderer
STUB_RENDERER_STATE=STOPPED
STUB_RENDERER_POSITION_SECONDS=0
STUB_RENDERER_DURATION_SECONDS=180

# Container runtime configuration.
MUSICD_MODE=serve
MUSICD_BIND_ADDR=0.0.0.0:8787
MUSICD_LIBRARY_PATH=/music
MUSICD_CONFIG_PATH=/config
MUSICD_PUBLIC_BASE_URL=http://localhost:8787
MUSICD_INSTANCE_NAME=musicd local
MUSICD_DISCOVERY_TIMEOUT_MS=2000
MUSICD_SERVER_DISCOVERY=true
# To force musicd to use the local stub renderer, set this to:
# MUSICD_DEFAULT_RENDERER_LOCATION=http://stub-renderer:9091/description.xml
MUSICD_DEFAULT_RENDERER_LOCATION=
MUSICD_DEBUG=true

# For local development, skip the startup library scan when /config/musicd.db
# already contains a persisted index. Use the UI/API rescan action when the
# library changes.
MUSICD_SKIP_STARTUP_SCAN=true

# Limit metadata scan parallelism. This helps when the library is a large
# network mount or Docker Desktop has a constrained memory budget.
RAYON_NUM_THREADS=2

# If you are testing playback to a real LAN renderer, set MUSICD_PUBLIC_BASE_URL
# to a URL the renderer can fetch, for example:
# MUSICD_PUBLIC_BASE_URL=http://192.168.1.84:8787
